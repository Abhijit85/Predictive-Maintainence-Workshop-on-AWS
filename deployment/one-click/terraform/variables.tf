variable "aws_cluster_name" {
  description = "Name for the ECS cluster."
  type        = string
  default     = "Pred-Maint-AWS-MongoDB"
}

variable "aws_container_name" {
  description = "Name for the ECS container."
  type        = string
  default     = "predictive-maintenance"
}

variable "aws_image" {
  description = "Full image (repository/prefix/name:tag) reference."
  type        = string
  default     = ""
}

variable "aws_app_name" {
  description = "Name used for app resources created on the ECS cluster and other services."
  type        = string
  default     = "pred-maint-aws-mongodb"
}

variable "aws_app_envs" {
  description = "Key-value pairs to be included in the environment variables used by the app."
  type        = map(string)
  default = {
    "PORT" : "3001"
  }
}

variable "app_indexing" {
  description = "Controls if indexing should be performed to MongoBD cluster."
  type        = bool
  default     = true
}

variable "app_generate_models" {
  description = "Controls if models should be generated by the application."
  type        = bool
  default     = false
}

variable "app_simulation" {
  description = "Controls if sample predictions using historical data should be perfomed by the app."
  type        = bool
  default     = true
}

variable "app_use_public_ecr" {
  description = "Controls if app should use the public image of the application."
  type        = bool
  default     = true
}

variable "atlas_create" {
  description = "Controls if Mongo Atlas cluster should be created."
  type        = bool
  default     = true
}

variable "atlas_project_name" {
  description = "Name of the MongoDB Atlas project"
  type        = string
  default     = "Pred-Maint-AWS-MongoDB"
}

variable "atlas_cluster_name" {
  description = "Name of the MongoDB Atlas cluster"
  type        = string
  default     = "predictive-maintenance"
}


variable "atlas_cluster_instance_size_name" {
  description = "Atlas cluster instance size (e.g., M0, M10)"
  type        = string
  default     = "M10"
}

variable "atlas_cluster_region_name" {
  description = "AWS region for the cluster"
  type        = string
  default     = "US_EAST_1"
}

