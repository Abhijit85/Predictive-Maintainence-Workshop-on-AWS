variable "atlas_org_id" {
  description = "The ID of the MongoDB Atlas organization"
  type        = string
  default     = ""
}

variable "atlas_public_key" {
  description = "Public key for MongoDB Atlas API"
  type        = string
  sensitive   = true
  default     = ""
}

variable "atlas_private_key" {
  description = "Private key for MongoDB Atlas API"
  type        = string
  sensitive   = true
  default     = ""
}

variable "atlas_password" {
  description = "Password for admin user."
  type        = string
  sensitive   = true
  default     = ""
}

variable "mongodb_uri" {
  description = "External MongoDB connection URI. Used when atlas_create is false."
  type        = string
  sensitive   = true
  default     = ""
}

variable "voyage_api_key" {
  description = "API key for Voyage AI embedding and reranking services."
  type        = string
  sensitive   = true
  default     = ""
}

variable "acm_certificate_arn" {
  description = "ARN of ACM certificate for HTTPS on the ALB. Leave empty for HTTP only."
  type        = string
  default     = ""
}

variable "alert_email" {
  description = "Email address for critical alert notifications via SNS."
  type        = string
  default     = ""
}